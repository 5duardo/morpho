{
  "name": "morpho",
  "version": "1.0.2",
  "description": "Aplicacion de escritorio para convertir formatos multimedia en lote.",
  "main": "src/main/main.js",
  "author": "Morpho",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win nsis",
    "pack": "electron-builder --dir",
    "lint": "node --check src/main/main.js && node --check src/main/converter.js && node --check src/main/imageConverter.js && node --check src/main/mediaConverter.js && node --check src/preload/preload.js && node --check src/renderer/app.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.morpho.desktop",
    "productName": "Morpho",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/renderer/assets/logo.png",
        "to": "logo.png",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg.exe",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
        "to": "ffprobe.exe",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "src/renderer/assets/logo.ico",
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "5duardo",
        "repo": "morpho",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
